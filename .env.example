DATABASE_URL="file:./dev.db"
PORT=3000

# Admin dashboard secret — set this to a long random string and enter it in MyBand_admin.
# If unset, the /admin/* endpoints return 503.
ADMIN_SECRET=""

# Primary Google OAuth client id. Keep this for backward compatibility.
GOOGLE_CLIENT_ID=""

# Optional additional Google OAuth client ids accepted by POST /auth/google.
# Use these when web, Android, and iOS apps issue ID tokens with different audiences.
GOOGLE_WEB_CLIENT_ID=""
GOOGLE_ANDROID_CLIENT_ID=""
GOOGLE_IOS_CLIENT_ID=""
GOOGLE_CLIENT_IDS=""

# Server-side JWT signing secret. Use a long random string in any non-local env.
JWT_SECRET=""
JWT_EXPIRES_IN="7d"

# Comma-separated additional frontend origins are supported with FRONTEND_URLS.
FRONTEND_URL="https://myband-fe.vercel.app"
FRONTEND_URLS=""

# Origin of the admin dashboard (e.g. https://admin.myband.example.com).
# Added to the CORS allowlist so the browser can reach the API.
ADMIN_URL=""

# Public base URL used when constructing static file URLs (images, PDFs).
# Must be the HTTPS origin — e.g. https://pagomnini.kro.kr
BASE_URL="https://pagomnini.kro.kr"
