{
  "name": "myband-be",
  "version": "0.1.0",
  "description": "MyBand backend server (Express + Tsoa + Prisma/SQLite)",
  "main": "dist/server.js",
  "scripts": {
    "tsoa": "tsoa spec-and-routes",
    "dev": "npm run tsoa && ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "npm run tsoa && tsc",
    "start": "node dist/server.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "test": "jest"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": ["**/src/__tests__/**/*.test.ts"],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {
        "tsconfig": {
          "module": "commonjs"
        }
      }]
    }
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^6.1.0",
    "@prisma/client": "^6.1.0",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.6",
    "dotenv": "^16.4.5",
    "express": "^5.0.1",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "swagger-ui-express": "^5.0.1",
    "tsoa": "^6.6.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.9.0",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/ws": "^8.18.1",
    "jest": "^30.4.2",
    "prisma": "^6.1.0",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.3"
  }
}
